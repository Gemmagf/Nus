# ============================================================
# Ernest — Variables d'entorn (còpia a .env i omple els valors)
# Massiu Soft SL
# ============================================================

# ── Dashboard web (Vite) ─────────────────────────────────────
# Obtinguts a: https://supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── App mòbil (Expo) ─────────────────────────────────────────
# Les mateixes claus Supabase, prefix EXPO_PUBLIC_ per a Expo
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL del backend Fastify (dev: localhost, prod: Railway URL)
EXPO_PUBLIC_API_URL=http://localhost:3001

# ── Backend API (Fastify) ────────────────────────────────────
# Service role key (NOMÉS al backend, mai al frontend!)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# JWT secret (ha de coincidir amb Supabase JWT secret)
JWT_SECRET=your-supabase-jwt-secret

# Port del servidor Fastify
PORT=3001

# Entorn (development | production)
NODE_ENV=development

# ── Sentry (monitoring d'errors) ─────────────────────────────
# Obtingut a: https://sentry.io → Settings → Projects → DSN
# Deixar buit per desactivar Sentry
SENTRY_DSN=
VITE_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_DSN=

# ── EAS (Expo Application Services) ─────────────────────────
# Obtingut a: https://expo.dev → Project → Settings
EAS_PROJECT_ID=
